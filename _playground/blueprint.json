{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Search Modal Block",
		"description": "Responsive search modal block.",
		"author": "philhoyt",
		"categories": [ "blocks" ]
	},
	"preferredVersions": {
		"php": "8.2",
		"wp": "latest"
	},
	"login": true,
	"landingPage": "/",
	"steps": [
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://github.com/philhoyt/search-modal-block/releases/latest/download/search-modal-block.zip"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "installTheme",
			"themeData": {
				"resource": "wordpress.org/themes",
				"slug": "twentytwentyfour"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Search Modal Block Demo"
			}
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/philhoyt/search-modal-block/main/_playground/demo-content.xml"
			}
		}
	]
}
