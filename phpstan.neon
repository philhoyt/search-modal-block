includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 5
    paths:
        - search-modal-block.php
    # Marked optional with (?) so PHPStan does not error when a path is
    # absent — e.g. the PHP-only CI job never installs node_modules.
    excludePaths:
        - vendor (?)
        - node_modules (?)
        - build (?)
        - tests (?)
