{
	"name": "search-modal-block",
	"version": "1.2.0",
	"description": "A customizable search modal block that adds an elegant and accessible search experience to your WordPress site.",
	"author": "Phil Hoyt",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"lint:scss": "wp-scripts lint-style 'src/**/*.scss'",
		"lint": "npm run lint:css && npm run lint:js && npm run lint:scss",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start",
		"test:unit": "wp-scripts test-unit-js",
		"test:e2e": "wp-scripts test-playwright",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"env:clean": "wp-env clean",
		"test:php": "wp-env run tests-cli --env-cwd wp-content/plugins/search-modal-block -- vendor/bin/phpunit"
	},
	"files": [
		"build",
		"assets",
		"index.php",
		"readme.txt",
		"search-modal-block.php",
		"src"
	],
	"devDependencies": {
		"@wordpress/env": "^11.8.1",
		"@wordpress/eslint-plugin": "^21.4.0",
		"@wordpress/scripts": "^27.9.0",
		"@wordpress/stylelint-config": "^21.41.0",
		"eslint": "^8.57.1",
		"stylelint": "^14.16.1"
	},
	"dependencies": {
		"@wordpress/icons": "^10.5.0",
		"micromodal": "^0.4.10"
	}
}
